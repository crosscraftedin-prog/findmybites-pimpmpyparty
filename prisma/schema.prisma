// FindMyBites x PimpMyParty - Global Marketplace Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Authenticated user (vendor). NOTE: Supabase Auth manages users in its own
// auth.users table — this model is optional and kept for future use (e.g.
// storing extra profile fields). The Vendor.userEmail is a plain string, not
// a FK to this table, to avoid constraint failures.
model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  image         String?
  emailVerified DateTime?
  createdAt     DateTime    @default(now())
  bookings      BookingV2[]
}

// Master category table — normalized, admin-managed, future-proof.
// The old CATEGORIES constant in constants.ts maps to these rows via the
// `slug` field (e.g. "bakers", "cake-artists", "djs").
model Category {
  id             String        @id @default(cuid())
  slug           String        @unique
  label          String
  ecosystem      String
  description    String?
  icon           String?
  image          String?
  accent         String?
  sortOrder      Int           @default(0)
  active         Boolean       @default(true)
  // ── Phase: DB-driven category metadata ──
  seoTitle       String?
  seoDescription String?
  featured       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  subcategories  Subcategory[]
}

// Subcategory table — belongs to a Category, admin-managed.
model Subcategory {
  id              String   @id @default(cuid())
  slug            String   @unique
  label           String
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  description     String?
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  isPending       Boolean  @default(false)
  addedByVendorId String?
  createdAt       DateTime @default(now())

  @@index([categoryId])
  @@map("Subcategory")
}

// A vendor / business listed on the marketplace.
// ecosystem: "FINDMYBITES" (food) or "PIMPMYPARTY" (events & party services)
model Vendor {
  id                String  @id @default(cuid())
  name              String
  slug              String  @unique
  ecosystem         String
  category          String
  tagline           String
  description       String
  city              String
  country           String
  countryCode       String
  continent         String
  currency          String
  priceRange        String
  basePrice         Int
  rating            Float   @default(0)
  reviewCount       Int     @default(0)
  heroImage         String
  avatarImage       String
  gallery           String
  tags              String
  featured          Boolean @default(false)
  verified          Boolean @default(true)
  // approval workflow: new vendor listings are pending (approved=false) until
  // an admin approves them. Only approved vendors show on the public site.
  approved          Boolean @default(false)
  responseTime      String
  yearsActive       Int     @default(1)
  completedBookings Int     @default(0)
  // contact + location details (optional, added for richer listings)
  subcategory       String?
  state             String?
  address           String?
  zipCode           String?
  instagram         String?
  website           String?
  whatsapp          String?
  // ── Social media (additional platforms) ──
  facebook          String?
  youtube           String?
  tiktok            String?
  twitter           String?
  snapchat          String?
  // ── India-specific ──
  fssaiNumber       String?
  // ── Listing settings ──
  settingsLocked    Boolean @default(false)
  // business settings
  openHours         String?
  deliveryAvailable Boolean @default(false)
  pickupAvailable   Boolean @default(false)
  serviceAreas      String?
  // SEO
  metaTitle         String?
  metaDescription   String?
  // geo coordinates for "Near Me" search (degrees). Nullable so legacy
  // vendors without a geocoded address are simply excluded from geo queries.
  latitude          Float?
  longitude         Float?
  // how far (km) this vendor will travel to serve a customer. Null = no limit
  // (e.g. a venue the customer travels to, or a vendor serving worldwide).
  serviceRadiusKm   Int?
  // owner: the authenticated vendor user who created this listing.
  // Stored as a plain string (not a FK) because auth users live in Supabase's
  // auth.users table, not our User table — a FK constraint would fail.
  userEmail         String?
  // Added by supabase_addon.sql — links to auth.users(id) for claim system.
  // Nullable because legacy vendors created before the claim system don't have it.
  owner_user_id     String?
  // Tracks the listing lifecycle: unclaimed → pending → approved/rejected
  ownership_status  String? @default("unclaimed")
  // How the vendor was onboarded: 'admin' (invited) or 'organic' (self-registered)
  invite_type       String? @default("organic")

  // ── Admin-Created Business Listings (Marketplace Growth System) ──
  // listing_status controls public visibility independently of ownership.
  // draft = admin is still editing; published = live on the marketplace;
  // claimed = owner has taken over; hidden = admin temporarily hid it;
  // rejected = admin rejected the listing.
  listingStatus     String? @default("published")
  // Where the listing data came from: manual | google | website | customer
  businessSource    String? @default("manual")
  // True if an admin created this listing (vs a vendor self-registering)
  adminCreated      Boolean  @default(false)
  // Phone number (separate from whatsapp) for claim verification
  phone             String?
  // Claim token for the "Claim this listing" flow (unique, expires)
  claimToken        String?  @unique
  claimTokenExpiresAt DateTime?
  // Invite tracking
  inviteStatus      String?  // pending | opened | claimed | expired | null
  inviteSentAt      DateTime?
  inviteOpenedAt    DateTime?
  // Claim tracking
  claimedAt         DateTime?
  claimedByUserId   String?
  // AI Suggestions (stored separately — never overwrites vendor content)
  aiSuggestions     String?

  // ── Business Profile Management ──
  businessType       String? // "home" | "shop" | "studio" | "cloud_kitchen" | "event_company" | "freelancer"
  yearStarted        Int?
  businessRegNumber  String?
  gstVatNumber       String?
  languagesSpoken    String? // comma-separated: "English, Hindi, Arabic"
  hideAddress        Boolean              @default(false)
  pinterest          String?
  linkedin           String?
  telegram           String?
  holidayMode        Boolean              @default(false)
  vacationMode       Boolean              @default(false)
  emergencyClosure   Boolean              @default(false)
  homeService        Boolean              @default(false)
  onlineConsultation Boolean              @default(false)
  maxOrder           Int?
  // Vendor-level preparation time & booking notice (free text, e.g. "24 hours", "2 days advance")
  prepTime           String?
  bookingNotice      String?
  responseRate       Int?                 @default(0) // percentage
  profileViews       Int                  @default(0)
  productViews       Int                  @default(0)
  galleryViews       Int                  @default(0)
  // Plan expiry — set when a Razorpay payment is verified.
  // Monthly → +30 days, Yearly → +365 days
  planExpiresAt      DateTime?
  createdAt          DateTime             @default(now())
  reviews            Review[]
  bookings           Booking[]
  products           Product[]
  availability       VendorAvailability[]
  subscriptions      VendorSubscription[]
  payments           PaymentHistory[]
  invoices           Invoice[]
  bookingsV2         BookingV2[]

  // ── Marketing & Growth Center relations ──
  growthScores       GrowthScore[]
  marketingCampaigns MarketingCampaign[]
  emailCampaigns     EmailCampaign[]
  reviewRequests     ReviewRequest[]
  referralsMade      Referral[]             @relation("ReferralReferrer")
  referralsJoined    Referral[]             @relation("ReferralInvitee")
  aiGenerationLogs   AiGenerationLog[]
  analyticsDaily     VendorAnalyticsDaily[]

  // ── Support System ──
  supportTickets     SupportTicket[]

  @@index([ecosystem])
  @@index([category])
  @@index([continent])
  @@index([featured])
  @@index([priceRange])
  @@index([rating])
  @@index([basePrice])
  @@index([countryCode])
  @@index([createdAt])
  @@index([approved])
  @@index([userEmail])
  @@index([city])
  @@index([state])
  @@index([latitude])
  @@index([longitude])
  // composite indexes for the most common filter+sort combos at scale
  @@index([ecosystem, category])
  @@index([ecosystem, continent])
  @@index([ecosystem, featured])
  @@index([ecosystem, priceRange])
  @@index([ecosystem, rating])
  @@index([ecosystem, approved])
  @@index([ecosystem, city])
  @@index([approved, latitude, longitude])
  @@index([listingStatus])
  @@index([ownership_status])
  @@index([adminCreated])
  @@index([phone])
  @@index([inviteStatus])
  @@map("vendor_listings")
}

// ── Vendor Claim / Invite Audit Trail ────────────────────────────────────
// Tracks every claim attempt and invite sent for admin-created listings.
// One row per invite/claim event — supports multiple attempts over time.

model VendorClaim {
  id          String   @id @default(cuid())
  vendorId    String   // references vendor_listings.id (loose, no FK)
  // Event type: invite_sent | invite_opened | claim_started | claim_approved | claim_rejected | token_regenerated
  eventType   String
  // Who initiated the event
  initiatedBy String?  // "admin" | "vendor" | "system"
  adminId     String?  // admin user id (if initiated by admin)
  adminEmail  String?  // admin email snapshot
  // Claimant info (for claim_started / claim_approved events)
  claimantEmail String?
  claimantUserId String?
  claimantName  String?
  // Token used (snapshot for audit)
  tokenSnippet String? // last 8 chars of the claim token
  // Metadata
  notes       String?  // free-form notes (e.g. rejection reason)
  metadata    String?  // JSON blob
  createdAt   DateTime @default(now())

  @@index([vendorId])
  @@index([eventType])
  @@index([createdAt])
  @@map("vendor_claims")
}

model Review {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  author    String
  avatar    String
  rating    Int
  comment   String
  eventDate String?
  createdAt DateTime @default(now())

  // ── Phase 5: Enhanced Reviews ──
  // Customer email (for verified purchase check)
  reviewerEmail   String?
  // Photos uploaded with the review (JSON array of URLs)
  photos          String?
  // Video URL (optional)
  videoUrl        String?
  // Verified purchase indicator (true if reviewer has a booking with this vendor)
  verified        Boolean   @default(false)
  // Vendor reply (optional)
  vendorReply     String?
  vendorRepliedAt DateTime?
  // Helpful votes count
  helpfulCount    Int       @default(0)
  // Report flags count
  reportCount     Int       @default(0)
  // Product this review is about (if applicable)
  productId       String?

  votes ReviewVote[]

  @@index([vendorId])
  @@index([reviewerEmail])
  @@index([verified])
  @@map("reviews")
}

model Booking {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name      String
  email     String
  eventType String
  eventDate String
  eventCity String
  guests    Int
  budget    String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())

  // ── Phase 4: Smart Enquiry & Booking System ──
  // Pipeline: new → viewed → contacted → quote_sent → negotiating → deposit_paid → confirmed → completed | cancelled
  phone            String?
  eventTime        String?
  address          String?
  notes            String?
  // Reference image uploaded by customer (URL)
  referenceImage   String?
  // Preferred contact method: "email" | "whatsapp" | "phone"
  preferredContact String?
  // Product this enquiry is about (if from a product page)
  productId        String?
  // AI-generated structured lead summary (e.g. "Wedding Cake · 150 guests · Chocolate · ₹15,000")
  aiSummary        String?
  // AI lead quality score (0-100)
  leadScore        Int?
  // AI-generated pre-qualification answers (JSON)
  aiQualification  String?
  // Concierge: if this enquiry was converted to a managed event
  conciergeEventId String?
  conciergeEvent   ConciergeEvent? @relation(fields: [conciergeEventId], references: [id], onDelete: SetNull)

  // Quotes sent to the customer for this enquiry
  quotes Quote[]

  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@index([conciergeEventId])
}

// ── Phase 4: Quotes ───────────────────────────────────────────────────────
// Vendors send quotes to customers for a specific enquiry/booking.
// A quote can include line items, deposit, and payment status.
model Quote {
  id                String    @id @default(cuid())
  bookingId         String
  booking           Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vendorId          String
  // Quote line items JSON: [{ label, qty, price }]
  lineItems         String    @default("[]")
  // Total amount in minor units (paise/cents)
  totalAmount       Int
  currency          String    @default("USD")
  // Deposit required (percentage or fixed amount)
  depositType       String    @default("percentage") // "percentage" | "fixed"
  depositValue      Int       @default(50) // percentage (0-100) or fixed amount
  // AI-generated quote notes/cover letter
  aiNotes           String?
  // Status: draft → sent → accepted → rejected → expired
  status            String    @default("draft")
  // Customer response
  customerResponse  String? // "accepted" | "rejected" | "changes_requested"
  customerNotes     String?
  // Razorpay payment for deposit
  razorpayOrderId   String?
  razorpayPaymentId String?
  depositPaidAt     DateTime?
  // Validity
  validUntil        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([bookingId])
  @@index([vendorId])
  @@index([status])
  @@map("quotes")
}

// ── Phase 4: Concierge Events ─────────────────────────────────────────────
// When a customer needs multiple vendors, Josh offers PimpMyParty Concierge
// to manage the entire event. This tracks managed events with multiple vendors.
model ConciergeEvent {
  id                 String   @id @default(cuid())
  customerName       String
  customerEmail      String
  customerPhone      String?
  eventType          String
  eventDate          String
  eventCity          String
  guests             Int
  budget             String
  notes              String?
  // Assigned event manager (admin email)
  eventManager       String?
  // Multiple vendors assigned to this event (JSON: [{ vendorId, role, quote }])
  assignedVendors    String   @default("[]")
  // Status: new → assigned → planning → confirmed → in_progress → completed
  status             String   @default("new")
  // Management fee (percentage or fixed)
  managementFeeType  String   @default("percentage")
  managementFeeValue Int      @default(10)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Bookings linked to this concierge event
  bookings Booking[]

  @@index([status])
  @@index([eventManager])
  @@index([createdAt])
  @@map("concierge_events")
}

// Products / services offered by a vendor within their single business listing.
// FindMyBites products: cakes, cupcakes, cookies, chocolates, catering, etc.
// PimpMyParty services: photography packages, DJ packages, decoration, venues.
model Product {
  id                 String   @id @default(cuid())
  vendorId           String
  vendor             Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name               String
  slug               String   @unique
  description        String?
  price              Int
  image              String?
  productType        String?
  // FindMyBites-specific
  sizes              String?
  flavours           String?
  weight             String?
  prepTime           String?
  deliveryAvailable  Boolean  @default(false)
  minGuests          Int?
  pricePerHead       Int?
  images             String?
  // ── NEW: enhanced product fields ──
  // media
  videoUrl           String?
  // pricing tiers (JSON: [{"label":"Small","price":100},{"label":"Large","price":200}])
  pricingTiers       String?
  // food-specific
  servings           String?
  shape              String?
  eggless            Boolean  @default(false)
  // availability
  sameDay            Boolean  @default(false)
  customOrder        Boolean  @default(false)
  pickupAvailable    Boolean  @default(false)
  // featured badge
  featured           Boolean  @default(false)
  // SEO
  metaTitle          String?
  metaDescription    String?
  // availability by location
  availableCountries String?
  availableStates    String?
  availableCities    String?
  // inventory
  inStock            Boolean  @default(true)
  stockCount         Int?
  // category-specific extra fields (JSON for flexibility)
  extraFields        String?
  createdAt          DateTime @default(now())
  // ── Package listing system fields ──
  ecosystem          String?
  category           String?
  packageType        String?  @default("standard")
  comparePrice       Int?
  currency           String?  @default("USD")
  duration           String?
  capacity           Int?
  includes           String? // JSON array
  dietaryTags        String? // JSON array
  addOns             String? // JSON array
  leadTime           String?
  isAvailable        Boolean  @default(true)
  isFeatured         Boolean  @default(false)
  sortOrder          Int      @default(0)
  updatedAt          DateTime @updatedAt

  // ── Product Management System: extended fields ──
  // FindMyBites food-specific
  subCategory      String?
  shortDescription String?
  vegetarian       Boolean @default(false)
  vegan            Boolean @default(false)
  halal            Boolean @default(false)
  glutenFree       Boolean @default(false)
  sugarFree        Boolean @default(false)
  spicyLevel       String? // "mild" | "medium" | "hot" | "extra_hot"
  ingredients      String? // long text
  allergenInfo     String? // long text

  // PimpMyParty package-specific
  includedServices   String? // JSON array
  optionalServices   String? // JSON array
  equipmentIncluded  String? // text
  indoorOutdoor      String? // "indoor" | "outdoor" | "both"
  travelAvailable    Boolean @default(false)
  bookingNotice      String? // e.g. "2 weeks"
  cancellationPolicy String? // text

  // Pricing options
  offerPrice        Int? // sale/discount price
  startingFromPrice Boolean @default(false) // show "Starting from" prefix
  hidePrice         Boolean @default(false) // don't show price publicly
  priceOnRequest    Boolean @default(false) // "Price on request"

  // Availability modes
  limitedTime     Boolean @default(false)
  customOrderOnly Boolean @default(false)

  // Analytics
  enquiryCount Int @default(0)

  // ── Variants, Inventory, Scheduling, Enhanced Analytics ──
  // Variants (JSON: [{name, price, offerPrice, sku, available, image}])
  variants           String?
  // Inventory
  stockType          String?   @default("unlimited") // "unlimited" | "limited" | "out_of_stock"
  lowStockThreshold  Int       @default(5)
  // Scheduling
  scheduledPublishAt DateTime?
  scheduledExpiryAt  DateTime?
  // Enhanced analytics
  whatsappClicks     Int       @default(0)
  orderCount         Int       @default(0)
  lastViewedAt       DateTime?

  // ── Food vendor enhanced fields ──
  allergens              String?
  customAllergen         String?
  cuisineType            String?
  customisationAvailable Boolean   @default(true)
  customisationNotes     String?
  shelfLife              String?
  storageMethod          String?
  storageInstructions    String?
  recipePublic           Boolean   @default(false)
  recipeText             String?
  recipePdf              String?
  // ── Marketing & deals ──
  discountPercent        Int?
  offerType              String?   @default("none")
  offerLabel             String?
  offerExpiresAt         DateTime?
  freeItemDescription    String?
  bundleDescription      String?
  bundleDiscount         Int?
  isFlashDeal            Boolean   @default(false)
  flashDealEndsAt        DateTime?
  minOrderForOffer       Int?
  exclusiveMemberOffer   Boolean   @default(false)
  // ── Phase 2.5: Product badges ──
  // badge: "featured" | "bestseller" | "new" | "seasonal" | "limited" | null
  badge                  String?
  // ── Template Engine v2: versioning ──
  // Stores which template version this product was created/last edited with.
  // Enables backward compatibility when templates evolve — old products
  // can still render with their original field structure.
  templateSlug           String?
  templateVersion        Int?

  // ── Inventory & Availability Management System ──
  // Unified lifecycle status (works for food products AND event packages).
  // active | draft | out_of_stock | temporarily_unavailable | seasonal | archived
  status                  String    @default("active")
  // Analytics: lifetime views (incremented on every public product page view)
  views                   Int       @default(0)
  // Lifetime sales revenue in smallest currency unit
  salesRevenue            Int       @default(0)
  // Maximum confirmed orders allowed per day (null = unlimited). Once the
  // daily confirmed-booking count reaches this, the product shows "Fully Booked".
  maxOrdersPerDay         Int?
  // Availability mode: "always" | "selected_days" | "date_range"
  availabilityMode        String    @default("always")
  // JSON array of weekday codes for "selected_days": ["MON","TUE",...,"SUN"]
  availableDays           String?
  // Date range for seasonal / limited-time products (e.g. Christmas Cakes)
  availabilityStart       DateTime?
  availabilityEnd         DateTime?
  // Structured preparation time category: same_day|24_hours|2_days|3_days|1_week|custom
  preparationTimeCategory String?
  // Custom preparation time label (when category = custom), e.g. "3-5 days"
  preparationTimeCustom   String?
  // Required advance booking notice in HOURS (e.g. 2, 24, 48, 168).
  // Customers cannot book earlier than this. null = no minimum notice.
  bookingNoticeHours      Int?
  // Service area scope for PimpMyParty packages: local|city|state|country|worldwide
  serviceAreaType         String?
  // JSON array of service cities (free-form, multiple allowed)
  serviceCities           String?
  // Admin override: when true the product is hidden from public marketplace
  // regardless of vendor status. Only admins can set this.
  forceHidden             Boolean   @default(false)
  // Internal admin notes (not visible to vendor or customer)
  adminNotes              String?
  // Season label for seasonal products, e.g. "Christmas 2025"
  seasonLabel             String?

  // ── Relations ──
  blockedDates   ProductBlockedDate[]
  analyticsDaily ProductAnalyticsDaily[]

  @@index([vendorId])
  @@index([productType])
  @@index([slug])
  @@index([featured])
  @@index([ecosystem])
  @@index([category])
  @@index([isAvailable])
  @@index([templateSlug])
  @@index([status])
  @@index([availabilityMode])
  @@index([availabilityStart])
  @@index([availabilityEnd])
  @@index([forceHidden])
}

// ── Product Calendar: Blocked Dates ───────────────────────────────────────
// Vendors block individual dates or date ranges for a product:
// holidays, vacations, fully-booked dates, or manual unavailability.
// Distinct from VendorAvailability (which is per-vendor). This is per-product.
model ProductBlockedDate {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Block type: "holiday" | "vacation" | "fully_booked" | "manual" | "maintenance"
  blockType String   @default("manual")
  // Single date (always set). For ranges, startDate = first day, endDate = last day.
  startDate DateTime
  endDate   DateTime
  // Optional human note, e.g. "Diwali holiday" or "Family vacation"
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([startDate])
  @@index([endDate])
  @@index([productId, startDate])
  @@map("product_blocked_dates")
}

// ── Product Analytics: Daily Aggregates ───────────────────────────────────
// One row per (product, day). Enables fast analytics charts + dashboards
// without scanning the full bookings table. Upserted by the analytics service.
model ProductAnalyticsDaily {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Calendar day in YYYY-MM-DD (vendor-local date)
  dateKey   String
  views     Int      @default(0)
  enquiries Int      @default(0)
  bookings  Int      @default(0)
  // Revenue booked that day (smallest currency unit)
  revenue   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, dateKey])
  @@index([productId, dateKey])
  @@index([dateKey])
  @@map("product_analytics_daily")
}

// ── Josh AI conversation persistence ──────────────────────────────────────
// Stores conversation history so Josh remembers context across sessions.
model JoshConversation {
  id                  String   @id @default(cuid())
  userId              String
  userEmail           String?
  userType            String   @default("customer") // "customer" | "vendor"
  vendorId            String? // if userType = vendor, their vendor listing id
  messages            Json     @default("[]") // [{role, content, timestamp}]
  conversationSummary String? // AI-generated summary after 10+ messages
  // ── Phase 6: Structured Conversation State ──
  // Deterministic intent state — updated after every message, never reparsed.
  // This is the source of truth for marketplace search, slot filling, and mode.
  state                Json     @default("{}") // ConversationState JSON
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastMessageAt       DateTime @default(now())

  @@index([userId])
  @@index([vendorId])
  @@map("josh_conversations")
}

// ── Dynamic pricing (admin-managed, multi-country) ────────────────────────
model Pricing {
  id                  String   @id @default(cuid())
  countryCode         String   @unique
  countryLabel        String
  symbol              String
  proMonthly          Int
  proYearlyTotal      Int // Annual total (one-time, ~20% off 12×monthly)
  businessMonthly     Int
  businessYearlyTotal Int // Annual total (one-time)
  note                String   @default("")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([countryCode])
  @@index([active])
  @@map("pricing")
}

// ── Universal Filter Engine ───────────────────────────────────────────────
// Admin-managed dynamic filters for categories/subcategories.
// Hierarchy: FilterGroup → FilterValues → assigned to Category via CategoryFilter
// Vendors select values via VendorFilterValue.

model FilterGroup {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "Cuisine", "Dietary", "Capacity"
  type      String   @default("multi") // "multi" | "single" | "range"
  unit      String? // for range: "guests", "sq_ft", "km"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  values     FilterValue[]
  categories CategoryFilter[]

  @@map("filter_groups")
}

model FilterValue {
  id        String   @id @default(cuid())
  groupId   String
  value     String // e.g. "Italian", "Vegetarian", "200"
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  group   FilterGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  vendors VendorFilterValue[]

  @@unique([groupId, value])
  @@index([groupId])
  @@map("filter_values")
}

model CategoryFilter {
  id            String   @id @default(cuid())
  categoryId    String // matches Vendor.category (e.g. "caterers", "venues")
  filterGroupId String
  required      Boolean  @default(false)
  createdAt     DateTime @default(now())

  filterGroup FilterGroup @relation(fields: [filterGroupId], references: [id], onDelete: Cascade)

  @@unique([categoryId, filterGroupId])
  @@index([categoryId])
  @@map("category_filters")
}

model VendorFilterValue {
  id            String   @id @default(cuid())
  vendorId      String
  filterValueId String
  createdAt     DateTime @default(now())

  filterValue FilterValue @relation(fields: [filterValueId], references: [id], onDelete: Cascade)

  @@unique([vendorId, filterValueId])
  @@index([vendorId])
  @@map("vendor_filter_values")
}

// ── Global Attribute System ──────────────────────────────────────────────
// Reusable, cross-category attributes (Dietary, Service, Product Features,
// Business Features). Unlike the category-scoped FilterGroup system above,
// global attributes apply across ALL categories — "Sugar Free" is the same
// attribute whether on a Cake, Cupcake, or Cookie.
//
// Architecture:
//   Attribute  →  VendorAttribute  →  Vendor  (vendor specialties)
//   Attribute  →  ProductAttribute →  Product (product badges)
//
// A product/vendor can have unlimited attributes. Attributes are global
// (not tied to a category) and are managed via the Admin Attribute Manager.
// Adding new attributes requires NO code changes — just a DB row.

model Attribute {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  group       String   // "dietary" | "service" | "product_feature" | "business"
  icon        String?
  color       String?
  description String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  ecosystem   String   @default("BOTH") // "FINDMYBITES" | "PIMPMYPARTY" | "BOTH"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendors     VendorAttribute[]
  products    ProductAttribute[]

  @@index([group, active, sortOrder])
  @@index([ecosystem, active])
  @@map("attributes")
}

model VendorAttribute {
  id          String    @id @default(cuid())
  vendorId    String
  attributeId String
  createdAt   DateTime  @default(now())

  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([vendorId, attributeId])
  @@index([vendorId])
  @@index([attributeId])
  @@map("vendor_attributes")
}

model ProductAttribute {
  id          String    @id @default(cuid())
  productId   String
  attributeId String
  createdAt   DateTime  @default(now())

  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@index([productId])
  @@index([attributeId])
  @@map("product_attributes")
}

// ── Template Engine (Enterprise v2) ───────────────────────────────────────
// Database-driven, admin-managed listing templates.
// Architecture: Business Type → Category → Subcategory → Template → Dynamic Fields
//
// Enterprise features:
//   - Versioning: templates have versions; old products stay compatible
//   - Inheritance: templates can inherit fields from a parent template
//   - Global Fields: shared fields inherited by all templates
//   - Repeatable Fields: vendors can add unlimited entries (e.g. multiple flavours)
//   - Multi-step: sections can be ordered as wizard steps
//   - Advanced Validation: min/max, regex, char limits, file size limits
//   - Searchable / SEO / AI flags per field
//   - Audit Log: tracks all template changes
//   - Import/Export: JSON backup & restore
//   - Safe Delete: prevents deleting in-use templates
//   - Usage Statistics: counts products + vendors per template

model ListingTemplate {
  id          String  @id @default(cuid())
  slug        String  @unique // e.g. "cake-bakery", "decoration", "photography"
  name        String // display name e.g. "Cake & Bakery Template"
  description String  @default("")
  ecosystem   String  @default("BOTH") // "FINDMYBITES" | "PIMPMYPARTY" | "BOTH"
  icon        String? // lucide icon name
  active      Boolean @default(true)
  // ── V3: Template lifecycle status ──
  // draft = admin is still editing (not shown to vendors)
  // published = live, vendors use this template
  // archived = retired, existing products keep using it but new products can't select it
  status      String  @default("published") // "draft" | "published" | "archived"
  // Sections JSON: [{ name, icon, defaultOpen, sortOrder, step? }]
  // step: optional step number for multi-step wizard forms
  sections    String  @default("[]")

  // ── Versioning ──
  // Current version number. When fields change structurally, bump version.
  // Existing products store the version they were created with in
  // Product.templateVersion, so old data never breaks.
  version  Int     @default(1)
  // Previous versions are stored as snapshots in TemplateVersionSnapshot
  isLatest Boolean @default(true)

  // ── Inheritance ──
  // If set, this template inherits all fields from the parent template
  // and can add/override its own. Resolution merges parent + child fields.
  parentTemplateId String?
  parent           ListingTemplate? @relation("TemplateInheritance", fields: [parentTemplateId], references: [id], onDelete: SetNull)

  // ── Global fields flag ──
  // Global templates are shared across all templates (Price, Gallery, etc.)
  // They're automatically merged into every resolved template.
  isGlobal Boolean @default(false)

  // ── Multi-step wizard config ──
  // JSON: [{ step, title, description, sections: ["Basic Information", ...] }]
  // When set, the form renders as a wizard with Next/Back buttons.
  wizard String @default("[]")

  // ── AI Readiness flags ──
  // Enable AI features for this template (description gen, SEO, tags)
  aiEnabled Boolean @default(false)
  aiConfig  String  @default("{}") // JSON: { descriptionPrompt, seoPrompt, tagPrompt }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields    TemplateField[]
  mappings  TemplateMapping[]
  children  ListingTemplate[]         @relation("TemplateInheritance")
  versions  TemplateVersionSnapshot[]
  auditLogs TemplateAuditLog[]

  @@map("listing_templates")
}

// Snapshot of a template at a specific version — for versioning & rollback.
model TemplateVersionSnapshot {
  id         String          @id @default(cuid())
  templateId String
  template   ListingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version    Int
  // Full JSON snapshot of the template + fields at this version
  snapshot   String          @default("{}")
  createdBy  String? // admin email
  changeNote String? // what changed in this version
  createdAt  DateTime        @default(now())

  @@unique([templateId, version])
  @@index([templateId])
  @@map("template_version_snapshots")
}

model TemplateField {
  id          String          @id @default(cuid())
  templateId  String
  template    ListingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  // The form-state key (e.g. "cakeShape", "price", "productType")
  key         String
  label       String
  // Field type controls which input component is rendered.
  // v1 types: text | number | textarea | select | chips | chips_single |
  //           toggle | toggle_group | images | section_toggle
  // v2 types: date | time | datetime | daterange | currency | price |
  //           address | phone | email | url | color | richtext | tags |
  //           gallery | videourl | fileupload | pdfupload | repeater |
  //           availability | bookingduration | radius
  type        String          @default("text")
  // Which section this field belongs to (matches a section name in template.sections)
  section     String          @default("Basic Information")
  sortOrder   Int             @default(0)
  required    Boolean         @default(false)
  enabled     Boolean         @default(true)
  placeholder String?
  helpText    String?
  // Suffix label e.g. "(kg)", "(g)", "(portions)"
  unit        String?
  // Grid column span: 1 = half width, 2 = full width (default 1)
  span        Int             @default(1)

  // ── Options ──
  // For select/chips/chips_single: load options from this FilterGroup name
  // (Universal Filter Engine). When set, staticOptions is ignored.
  filterGroupName String?
  // For select/chips/chips_single/toggle_group: static options as JSON array
  // Used as fallback when filterGroupName is not set or filter group is empty
  staticOptions   String? // JSON: ["Option1", "Option2"]

  // ── Conditional visibility ──
  // JSON: { "field": "productType", "values": ["Cakes", ""] }
  // Field is visible only when form[condition.field] is in condition.values.
  // Built visually in the Admin Panel (Visual Conditional Logic Builder).
  condition String?

  // ── Section toggle ──
  // For section_toggle: keys of sub-fields revealed when toggle is on
  // JSON: ["nameOnCakeText", "nameOnCakeMaxChars"]
  subFields String?

  // ── Toggle group ──
  // For toggle_group: the option labels (default ["Yes", "No"])
  toggleOptions String?

  // ── Media limits ──
  maxImages   Int? // for images/gallery: max number of photos
  maxFileSize Int? // for fileupload/pdfupload: max size in KB

  // ── Number validation ──
  minValue Int?
  maxValue Int?
  step     Float?

  // ── Text validation (v2) ──
  minLength   Int? // min characters
  maxLength   Int? // max characters
  pattern     String? // regex pattern for validation
  patternHint String? // human-readable validation hint

  // ── Repeatable fields (v2) ──
  // If true, vendors can add unlimited entries of this field.
  // The form state stores an array. minRepeats/maxRepeats control limits.
  repeatable   Boolean @default(false)
  minRepeats   Int?
  maxRepeats   Int?
  // For repeater: the label for each entry (e.g. "Flavour", "Size")
  repeatLabel  String?
  // For repeater with sub-fields: JSON array of field definitions
  // (enables grouped repeaters like multiple menu items with name+price+desc)
  repeatFields String?

  // ── Search / SEO / AI / Filter flags (v2/v3) ──
  // searchable: field value is indexed for marketplace search & filtering
  searchable Boolean @default(false)
  // seoIndexed: field value is included in auto-generated SEO pages
  seoIndexed Boolean @default(false)
  // aiEnabled: field is available for AI features (description gen, tag suggestions)
  aiEnabled  Boolean @default(false)
  // filterable: field appears as a marketplace filter facet (auto-generated filter UI)
  filterable Boolean @default(false)
  // priority: controls field display order in Josh AI context + SEO (higher = more prominent)
  priority  Int     @default(0)

  // ── Global field reference ──
  // If this field was inherited from a global template, this stores the
  // original global template slug so we can track provenance.
  globalRef String?

  createdAt DateTime @default(now())

  @@index([templateId])
  @@index([section])
  @@index([searchable])
  @@index([seoIndexed])
  @@index([templateId, section, sortOrder])
  @@map("template_fields")
}

// Maps a category (and optionally subcategory) to a template.
// Admins can change which template a category uses without touching code.
// Resolution order: subcategory match → category match → ecosystem default.
model TemplateMapping {
  id          String          @id @default(cuid())
  categoryId  String // matches Vendor.category slug (e.g. "bakers-bakery")
  subcategory String? // optional: matches Vendor.subcategory (e.g. "Wedding Cakes")
  templateId  String
  template    ListingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())

  @@unique([categoryId, subcategory])
  @@index([categoryId])
  @@index([templateId])
  @@map("template_mappings")
}

// ── Template Audit Log ────────────────────────────────────────────────────
// Tracks all template changes for troubleshooting and change management.
model TemplateAuditLog {
  id            String          @id @default(cuid())
  templateId    String
  template      ListingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  action        String // "create" | "update" | "delete" | "duplicate" | "version_bump" | "field_add" | "field_update" | "field_delete" | "mapping_add" | "mapping_delete" | "seed" | "import" | "export"
  entity        String          @default("template") // "template" | "field" | "mapping"
  entityId      String?
  fieldName     String? // which field was changed (for field actions)
  changeSummary String? // human-readable summary
  // JSON diff: { before: {...}, after: {...} }
  changeData    String          @default("{}")
  adminEmail    String?
  createdAt     DateTime        @default(now())

  @@index([templateId])
  @@index([action])
  @@index([createdAt])
  @@index([templateId, createdAt])
  @@map("template_audit_logs")
}

// ── Vendor Analytics ──────────────────────────────────────────────────────
// Tracks customer interactions with vendor storefronts for the vendor dashboard.
// Events: page_view, product_view, service_view, contact_click, whatsapp_click,
//         phone_click, website_click, share_click, gallery_view
model VendorAnalytics {
  id          String   @id @default(cuid())
  vendorId    String
  // Event type: page_view | product_view | service_view | contact_click |
  //             whatsapp_click | phone_click | website_click | share_click
  eventType   String
  // Optional: which product/service was viewed/clicked
  productId   String?
  // Optional: visitor metadata (for deduplication, not for tracking individuals)
  visitorHash String? // hashed IP + user agent for unique visitor counting
  // Optional: referrer (where the visitor came from)
  referrer    String?
  createdAt   DateTime @default(now())

  @@index([vendorId])
  @@index([eventType])
  @@index([createdAt])
  @@index([vendorId, eventType, createdAt])
  @@map("vendor_analytics")
}

// ── Phase 2.5: Customer Follow (follow vendors) ───────────────────────────
// Customers can follow vendors to receive updates on new products, seasonal
// offers, festival collections, and promotions.
model VendorFollow {
  id        String   @id @default(cuid())
  vendorId  String
  // Customer identifier — supabase auth user ID (for logged-in customers)
  // or a visitor hash (for anonymous followers, stored in localStorage)
  userId    String
  userEmail String?
  createdAt DateTime @default(now())

  @@unique([vendorId, userId])
  @@index([vendorId])
  @@index([userId])
  @@map("vendor_follows")
}

// ── Phase 2.5: Customer Wishlist ──────────────────────────────────────────
// Customers can save products, services, and vendors to their wishlist.
// entityType: "product" | "service" | "vendor"
model Wishlist {
  id         String   @id @default(cuid())
  userId     String
  userEmail  String?
  entityType String // "product" | "service" | "vendor"
  entityId   String // product ID or vendor ID
  vendorId   String? // for product/service wishlist items, the parent vendor
  createdAt  DateTime @default(now())

  @@unique([userId, entityType, entityId])
  @@index([userId])
  @@index([entityType])
  @@index([vendorId])
  @@map("customer_wishlist")
}

// ── Phase 5: Messaging System ─────────────────────────────────────────────
// Supports: Customer↔Vendor, Admin↔Vendor, Admin↔Customer, Josh AI↔Customer
// Conversations are threaded between two participants.
model Conversation {
  id               String    @id @default(cuid())
  // Participants: identified by type + id
  participant1Type String // "customer" | "vendor" | "admin" | "josh_ai"
  participant1Id   String // user ID or vendor ID
  participant2Type String
  participant2Id   String
  // Optional context: which vendor/product is this conversation about?
  vendorId         String?
  productId        String?
  bookingId        String?
  // Last message preview (for inbox display)
  lastMessage      String?
  lastMessageAt    DateTime?
  // Unread counts per participant
  unreadCount1     Int       @default(0)
  unreadCount2     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  messages Message[]

  @@unique([participant1Type, participant1Id, participant2Type, participant2Id])
  @@index([participant1Type, participant1Id])
  @@index([participant2Type, participant2Id])
  @@index([vendorId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // Sender info
  senderType     String // "customer" | "vendor" | "admin" | "josh_ai"
  senderId       String
  senderName     String
  senderAvatar   String?
  // Message content
  content        String
  // Attachments (JSON array of URLs for images/files)
  attachments    String? // JSON: [{ type: "image"|"file"|"quote", url, name }]
  // Quote attachment (if this message includes a quote)
  quoteId        String?
  // Read receipt
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderType, senderId])
  @@index([createdAt])
  @@map("messages")
}

// ── Phase 5: Notifications ────────────────────────────────────────────────
// Central notification system for all user types.
// One table serves customers, vendors, and admins.
model Notification {
  id             String    @id @default(cuid())
  // Recipient: identified by type + id
  recipientType  String // "customer" | "vendor" | "admin"
  recipientId    String // user ID, vendor ID, or "admin" for all admins
  // Notification content
  type           String // "new_quote" | "vendor_replied" | "booking_confirmed" | "payment_received" |
  // "new_enquiry" | "new_message" | "quote_accepted" | "deposit_received" |
  // "concierge_assigned" | "new_signup" | "pending_approval" | "ai_flagged"
  title          String
  message        String
  // Optional context links
  vendorId       String?
  productId      String?
  bookingId      String?
  quoteId        String?
  conversationId String?
  // Action URL (where clicking the notification should go)
  actionUrl      String?
  // Read status
  read           Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([recipientType, recipientId, read])
  @@index([recipientType, recipientId, createdAt])
  @@index([createdAt])
  @@map("notifications")
}

// ── Phase 5: Vendor Calendar & Availability ───────────────────────────────
// Vendors mark dates as available, busy, booked, or holiday.
// Josh AI uses this when recommending vendors.
model VendorAvailability {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  date      DateTime
  // Status: "available" | "busy" | "booked" | "holiday" | "partial"
  status    String   @default("available")
  // For partial availability: time slots JSON [{ start, end, status }]
  timeSlots String?
  // Optional note (e.g. "Morning only", "Wedding booked")
  note      String?
  // If booked, link to the booking
  bookingId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, date])
  @@index([vendorId, date])
  @@index([status])
  @@map("vendor_availability")
}

// ── Phase 5: Review Helpful Votes ─────────────────────────────────────────
// Tracks who voted a review as helpful (to prevent duplicate votes)
model ReviewVote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String // customer ID or visitor hash
  helpful   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@map("review_votes")
}

// ── Subscription Lifecycle Management ─────────────────────────────────────
// Production-ready subscription system built on top of the existing Razorpay
// Orders integration. Designed so that Razorpay Subscriptions (AutoPay) can
// replace Razorpay Orders later WITHOUT changing the dashboard, billing
// history, expiry logic, or feature gating.
//
// The `provider` field makes the billing layer provider-agnostic:
//   - "razorpay_orders"       (current — one-time payments, manual renewal)
//   - "razorpay_subscriptions" (future — AutoPay, automatic recurring)
//   - "stripe"                 (future — international)
//
// Only the payment provider module changes; the subscription record,
// expiry math, feature gating, and billing history stay the same.

model VendorSubscription {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // ── Plan details ──
  planName     String // "vendor-pro" | "business"
  planTier     String @default("pro") // "pro" | "business" (human label)
  billingCycle String @default("monthly") // "monthly" | "yearly"
  status       String @default("active") // "active" | "expired" | "cancelled" | "past_due"

  // ── Billing window ──
  planStartedAt   DateTime  @default(now())
  planExpiresAt   DateTime // 30 days (monthly) or 365 days (yearly) after start
  nextRenewalDate DateTime? // null for one-time orders; set for future AutoPay
  cancelledAt     DateTime?

  // ── Provider (modular — swap without touching expiry/gating logic) ──
  provider               String  @default("razorpay_orders") // "razorpay_orders" | "razorpay_subscriptions" | "stripe"
  providerSubscriptionId String? // Razorpay subscription_id (future AutoPay) or stripe sub id
  razorpayCustomerId     String? // Razorpay customer_id (reused for renewals + Dashboard)

  // ── Pricing snapshot at activation (immutable record of what was paid) ──
  amountPaid Int // in smallest currency unit (paise/cents/fils)
  currency   String @default("INR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──
  payments PaymentHistory[]
  invoices Invoice[]

  @@index([vendorId])
  @@index([status])
  @@index([planExpiresAt])
  @@index([provider])
  @@index([providerSubscriptionId])
  @@index([razorpayCustomerId])
  @@map("vendor_subscriptions")
}

// ── Payment History (immutable audit log of every payment) ────────────────
// Every successful payment creates a row here. Used by the Billing History
// page and admin revenue reports. Never updated after creation (append-only).

model PaymentHistory {
  id             String              @id @default(cuid())
  vendorId       String
  vendor         Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   VendorSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  // ── Payment details ──
  orderId       String // Razorpay order_id
  paymentId     String  @unique // Razorpay payment_id (prevent duplicate processing)
  invoiceNumber String? // generated invoice number (e.g. FMB-INV-2024-00001)
  signature     String? // stored for audit (HMAC verified at activation)

  // ── Plan + amount ──
  planName      String // "vendor-pro" | "business"
  billingCycle  String @default("monthly")
  amount        Int // smallest currency unit
  currency      String @default("INR")
  paymentStatus String @default("captured") // "captured" | "failed" | "refunded"

  // ── Provider ──
  provider      String  @default("razorpay_orders")
  paymentMethod String? // "upi" | "card" | "netbanking" | "wallet" (from Razorpay)

  // ── Type ──
  paymentType String @default("new") // "new" | "renewal"

  // ── Relations ──
  invoices Invoice[]

  createdAt DateTime @default(now())

  @@index([vendorId])
  @@index([subscriptionId])
  @@index([orderId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("payment_history")
}

// ── Subscription System V3 — Database-Driven Billing ──────────────────────
//
// PricingPlan: One record per country + plan + billing cycle.
// Replaces the V2 hardcoded PRICING_BY_COUNTRY config and env-var Plan IDs.
// Admin can edit pricing and Razorpay Plan IDs without code deployment.

model PricingPlan {
  id             String   @id @default(cuid())
  countryCode    String   // ISO 3166-1 alpha-2 (IN, US, GB, etc.)
  countryName    String   // "India", "United States", etc.
  currency       String   // ISO 4217 (INR, USD, GBP, etc.)
  currencySymbol String   // ₹, $, £, etc.
  plan           String   // "pro" | "business"
  billingCycle   String   // "monthly" | "yearly"
  displayPrice   Float    // Price in main unit (e.g. 299 for ₹299)
  amountMinor    Int      // Smallest currency unit (e.g. 29900 paise)
  razorpayPlanId String?  // Razorpay Plan object ID (null = use Orders fallback)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([countryCode, plan, billingCycle])
  @@index([countryCode])
  @@index([plan])
  @@index([active])
  @@map("pricing_plans")
}

// PromoCode: Discount codes for subscription campaigns.
// Supports percentage and fixed-amount discounts, country/plan-specific offers.

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String    @default("")
  countryCode   String?   // null = all countries
  plan          String?   // null = all plans ("pro" | "business")
  billingCycle  String?   // null = all cycles ("monthly" | "yearly")
  discountType  String    @default("percentage") // "percentage" | "fixed"
  discountValue Float     // e.g. 20 for 20% off, or 100 for ₹100 off
  maxUses       Int       @default(0) // 0 = unlimited
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
  @@index([countryCode])
  @@index([active])
  @@map("promo_codes")
}

// Invoice: Professional invoices generated for each payment.
// Stored in the database with a file path to the generated PDF.

model Invoice {
  id             String   @id @default(cuid())
  vendorId       String
  vendor         Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  paymentHistoryId String?  // FK to PaymentHistory
  paymentHistory   PaymentHistory? @relation(fields: [paymentHistoryId], references: [id], onDelete: SetNull)
  subscriptionId String?
  subscription   VendorSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  invoiceNumber  String   @unique // e.g. FMB-INV-2026-00001
  invoiceDate    DateTime @default(now())

  // ── Billing details ──
  planName       String
  billingCycle   String
  countryCode    String
  currency       String
  currencySymbol String

  // ── Amounts (all in minor units) ──
  subtotal       Int      @default(0)
  discount       Int      @default(0)
  tax            Int      @default(0)
  total          Int

  // ── Promo code (if applied) ──
  promoCode      String?

  // ── Razorpay references ──
  razorpayPaymentId  String?
  razorpayOrderId    String?

  // ─── Status ──
  status         String   @default("paid") // "paid" | "pending" | "failed" | "refunded"

  // ── File path (generated PDF) ──
  filePath       String?

  createdAt      DateTime @default(now())

  @@index([vendorId])
  @@index([paymentHistoryId])
  @@index([invoiceNumber])
  @@map("invoices")
}

// WebhookLog: Immutable audit log of every Razorpay webhook received.
// Used for debugging, retry, and idempotency verification.

model WebhookLog {
  id             String   @id @default(cuid())
  eventId        String   @unique // Razorpay event ID (prevents duplicate processing)
  eventType      String   // e.g. "subscription.charged"
  entity         String   // "subscription" | "payment"
  entityId       String?  // Razorpay subscription/payment ID
  payload        Json     // Full webhook payload (for audit/debugging)
  signature      String?  // X-Razorpay-Signature header
  processed      Boolean  @default(false)
  processedAt    DateTime?
  error          String?  // Error message if processing failed
  createdAt      DateTime @default(now())

  @@index([eventId])
  @@index([eventType])
  @@index([processed])
  @@map("webhook_logs")
}

// BillingSettings: Admin-configurable billing settings (single row).
model BillingSettings {
  id              String   @id @default("default")
  invoicePrefix   String   @default("FMB-INV")
  gracePeriodDays Int      @default(3)
  retryCount      Int      @default(3)
  retryIntervalHr Int      @default(48)
  reminderDays    String   @default("7,3,1,0")
  defaultCurrency String   @default("USD")
  fallbackCountry String   @default("US")
  supportEmail    String   @default("hello@findmybites.party")
  taxPercentage   Float    @default(0)
  invoiceFooter   String   @default("Thank you for your business!")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("billing_settings")
}

// Production-ready booking system designed for millions of rows.
// This is a NEW model alongside the existing `Booking` (enquiry) model —
// the existing model is NOT modified.
//
// Future-ready architecture:
//   - depositAmount + depositStatus: support deposits/partial payments
//   - commissionAmount + commissionRate: support marketplace commission
//   - invoiceNumber: support invoices
//   - escrowStatus: support escrow (future)
//   - couponCode: support coupons
//   - recurrenceRule: support recurring services (iCal RRULE)
//   - calendarSyncToken: support Google/Outlook/Apple Calendar sync
//   - provider-agnostic notification events (email/whatsapp/push-ready)

model BookingV2 {
  id            String @id @default(cuid())
  bookingNumber String @unique // human-readable: FMB-BKG-YYYY-NNNNN
  vendorId      String
  vendor        Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // ── Customer info ──
  customerName  String
  customerPhone String
  customerEmail String
  // Optional link to an authenticated User (if the customer is logged in)
  customerId    String?
  customer      User?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // ── Event details ──
  eventType    String // "Wedding", "Birthday", "Corporate", etc.
  bookingDate  DateTime // the event date
  bookingTime  String // "14:00" (time of day)
  address      String // delivery / event address
  city         String
  guests       Int      @default(0)
  budget       Int      @default(0) // in smallest currency unit (paise)
  currency     String   @default("INR")
  specialNotes String? // customer notes

  // ── Products / Services ──
  // JSON array: [{ productId, name, qty, price }]
  items       String @default("[]")
  totalAmount Int    @default(0) // sum of items, in smallest currency unit

  // ── Status (booking lifecycle) ──
  // pending → confirmed → accepted → in_progress → completed
  //                    ↘ rejected
  //         → cancelled (at any point)
  //         → refunded (future)
  status String @default("pending") // pending|confirmed|accepted|rejected|in_progress|completed|cancelled|refunded

  // ── Reference image (customer upload) ──
  referenceImage String?

  // ── Future-ready: payments ──
  depositAmount    Int     @default(0) // deposit required (smallest unit)
  depositStatus    String  @default("none") // none|required|paid|partial|refunded
  paymentStatus    String  @default("unpaid") // unpaid|deposit_paid|partially_paid|paid|refunded
  escrowStatus     String  @default("none") // none|held|released|refunded
  commissionRate   Float   @default(0) // marketplace commission percentage (0-100)
  commissionAmount Int     @default(0) // computed commission (smallest unit)
  couponCode       String?

  // ── Future-ready: invoicing ──
  invoiceNumber String?

  // ── Future-ready: recurring services ──
  recurrenceRule String? // iCal RRULE string (e.g. "FREQ=WEEKLY;BYDAY=MO")

  // ── Future-ready: calendar sync ──
  calendarSyncToken String? // Google/Outlook sync token
  calendarEventId   String? // external calendar event ID

  // ── Internal (vendor-only) notes ──
  internalNotes String?

  // ── Reassignment (admin) ──
  reassignedFrom String? // previous vendorId if reassigned
  reassignedAt   DateTime?
  reassignedBy   String? // admin user id

  // ── Audit ──
  createdBy       String? // user id or "guest"
  cancelledReason String?
  cancelledAt     DateTime?
  rejectedReason  String?
  rejectedAt      DateTime?
  completedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──
  notes  BookingNote[]
  events BookingEvent[]

  // ── Scalable indexes (designed for millions of rows) ──
  @@index([vendorId])
  @@index([customerId])
  @@index([customerEmail])
  @@index([status])
  @@index([bookingDate])
  @@index([city])
  @@index([createdAt])
  @@index([vendorId, status])
  @@index([vendorId, bookingDate])
  @@index([status, bookingDate])
  @@index([customerEmail, status])
  @@map("bookings_v2")
}

// ── Booking Notes (internal vendor notes + customer-visible notes) ────────
model BookingNote {
  id         String    @id @default(cuid())
  bookingId  String
  booking    BookingV2 @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  authorId   String? // user id (vendor or admin)
  authorName String
  authorRole String    @default("vendor") // "vendor" | "admin" | "customer"
  note       String
  isInternal Boolean   @default(true) // internal = vendor-only; false = customer-visible
  createdAt  DateTime  @default(now())

  @@index([bookingId])
  @@index([createdAt])
  @@map("booking_notes")
}

// ── Booking Events (audit log + notification source) ─────────────────────
// Every status change + action creates an immutable event row.
// This is the audit log (Step: Security) and the source for notifications.
model BookingEvent {
  id                String    @id @default(cuid())
  bookingId         String
  booking           BookingV2 @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  eventType         String // "created"|"accepted"|"rejected"|"rescheduled"|"completed"|"cancelled"|"reminder_24h"|"note_added"|"reassigned"
  actorId           String? // user id who performed the action
  actorRole         String    @default("system") // "vendor"|"admin"|"customer"|"system"
  metadata          String? // JSON: { oldStatus, newStatus, oldDate, newDate, ... }
  // ── Notification delivery status (provider-agnostic) ──
  notifEmailSent    Boolean   @default(false)
  notifWhatsappSent Boolean   @default(false)
  notifPushSent     Boolean   @default(false)
  createdAt         DateTime  @default(now())

  @@index([bookingId])
  @@index([eventType])
  @@index([createdAt])
  @@map("booking_events")
}

// ── Marketing & Growth Center ─────────────────────────────────────────────
// Comprehensive marketing toolkit: campaigns, AI-generated social/email/
// whatsapp content, QR codes, review requests, referrals, growth snapshots.

// Vendor's current growth score + breakdown (snapshot for trend tracking).
// Recomputed on demand; latest row per vendor is the current score.
model GrowthScore {
  id         String   @id @default(cuid())
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  // Overall 0-100
  score      Int      @default(0)
  // Star rating 0-5
  stars      Int      @default(0)
  // Breakdown JSON: { profileComplete, products, seo, photos, responseRate, reviews, subscription }
  breakdown  String?
  // Plain-text list of weak areas for the AI advisor
  weakAreas  String?
  computedAt DateTime @default(now())

  @@index([vendorId, computedAt])
  @@map("growth_scores")
}

// Marketing campaigns (coupons, festivals, flash sales, referral, etc.)
model MarketingCampaign {
  id              String    @id @default(cuid())
  vendorId        String
  vendor          Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  // coupon | festival | weekend | birthday | wedding_season | referral | flash_sale | countdown
  type            String
  name            String
  // Optional coupon code (for coupon/flash_sale types)
  code            String?
  // discount percent (0-100) or flat amount in smallest currency unit
  discountPercent Int?
  discountAmount  Int?
  currency        String    @default("INR")
  // AI-generated marketing copy
  headline        String?
  description     String?
  terms           String?
  // Scheduling
  startsAt        DateTime?
  endsAt          DateTime?
  // Status: draft | active | paused | expired
  status          String    @default("draft")
  // Engagement counters
  views           Int       @default(0)
  clicks          Int       @default(0)
  redemptions     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([vendorId])
  @@index([vendorId, status])
  @@index([type])
  @@index([status, startsAt])
  @@map("marketing_campaigns")
}

// Email campaigns / newsletters
model EmailCampaign {
  id             String    @id @default(cuid())
  vendorId       String
  vendor         Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  // Template: new_product | festival | special_offer | thank_you | booking_reminder | re_engagement
  template       String
  subject        String
  preheader      String?
  body           String
  // Recipient list size snapshot
  recipientCount Int       @default(0)
  // Sent stats
  sentAt         DateTime?
  openedCount    Int       @default(0)
  clickedCount   Int       @default(0)
  status         String    @default("draft") // draft | sent | scheduled
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([vendorId])
  @@index([vendorId, status])
  @@map("email_campaigns")
}

// Review booster: track review requests sent and received
model ReviewRequest {
  id              String    @id @default(cuid())
  vendorId        String
  vendor          Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  // channel: whatsapp | email | sms | qr
  channel         String
  // The customer this request was sent to (optional)
  customerName    String?
  customerContact String?
  // Token for the public review-landing link
  token           String    @unique
  // Status: sent | opened | completed | ignored
  status          String    @default("sent")
  sentAt          DateTime  @default(now())
  openedAt        DateTime?
  completedAt     DateTime?

  @@index([vendorId])
  @@index([vendorId, status])
  @@index([token])
  @@map("review_requests")
}

// Referral program: track vendor-to-vendor referrals
model Referral {
  id               String    @id @default(cuid())
  referrerVendorId String
  referrer         Vendor    @relation("ReferralReferrer", fields: [referrerVendorId], references: [id], onDelete: Cascade)
  // The invited vendor's email (used to match on signup)
  inviteeEmail     String
  // The vendor that signed up (set when activated)
  inviteeVendorId  String?
  invitee          Vendor?   @relation("ReferralInvitee", fields: [inviteeVendorId], references: [id], onDelete: SetNull)
  // Unique referral code
  code             String    @unique
  // Status: sent | activated | rewarded
  status           String    @default("sent")
  // Reward tracking
  creditsEarned    Int       @default(0)
  commissionEarned Int       @default(0)
  sentAt           DateTime  @default(now())
  activatedAt      DateTime?
  rewardedAt       DateTime?

  @@index([referrerVendorId])
  @@index([inviteeEmail])
  @@index([code])
  @@map("referrals")
}

// AI generation log — for admin analytics + rate limiting
model AiGenerationLog {
  id        String   @id @default(cuid())
  vendorId  String?
  vendor    Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  // feature: growth_advisor | social_post | email_campaign | whatsapp_msg | seo | campaign_copy
  feature   String
  // tokens used (approx)
  tokens    Int      @default(0)
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([vendorId])
  @@index([feature])
  @@index([createdAt])
  @@map("ai_generation_logs")
}

// Daily marketing analytics aggregate (per vendor, per day).
// Mirrors ProductAnalyticsDaily but for the vendor profile as a whole.
model VendorAnalyticsDaily {
  id           String   @id @default(cuid())
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  dateKey      String // YYYY-MM-DD
  profileViews Int      @default(0)
  productViews Int      @default(0)
  enquiries    Int      @default(0)
  bookings     Int      @default(0)
  revenue      Int      @default(0)
  follows      Int      @default(0)
  wishlistAdds Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([vendorId, dateKey])
  @@index([vendorId, dateKey])
  @@index([dateKey])
  @@map("vendor_analytics_daily")
}

// ── Admin Audit Log ────────────────────────────────────────────────────────
// Immutable record of destructive admin actions (vendor deletion, force-hide,
// bulk operations). Each entry captures who/what/when/why for compliance.
model AdminAuditLog {
  id          String   @id @default(cuid())
  // "vendor_delete" | "vendor_bulk_delete" | "vendor_cleanup_test" | ...
  action      String
  // Admin's supabase user id (from session) or email
  adminId     String
  adminEmail  String?
  // Target vendor id(s) — single id for vendor_delete, comma-separated for bulk
  targetId    String
  targetName  String?  // vendor name snapshot (for display after deletion)
  // Free-form reason entered by the admin
  reason      String?
  // JSON blob with extra context (e.g. { vendorCount, storagePaths })
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([adminId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ── Vendor Support & Admin Messaging System ────────────────────────────────
// WhatsApp-style support tickets between vendors and platform admins.
// Each ticket is a conversation thread with messages, attachments, and
// a full status workflow. Future-ready for live chat / AI chatbot / email
// integration via the polymorphic channel field.

model SupportTicket {
  id              String   @id @default(cuid())
  // Ticket number for human display: SUP-YYYY-NNNNN
  ticketNumber    String   @unique
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // ── Ticket metadata ──
  subject         String
  // account | business_listing | subscription | payments | products | photos |
  // reviews | claim_business | technical_bug | feature_request | other
  category        String
  // low | medium | high | urgent
  priority        String   @default("medium")
  // open | pending | waiting_vendor | in_progress | resolved | closed
  status          String   @default("open")

  // ── Auto-captured context (stored once at creation) ──
  businessName    String?
  vendorEmail     String?
  vendorPhone     String?
  browserInfo     String?
  dashboardUrl    String?

  // ── Assignment ──
  assignedTo      String?  // admin user id
  assignedToEmail String?  // admin email snapshot

  // ── Internal admin notes (not visible to vendor) ──
  internalNotes   String?  // JSON array of {note, adminEmail, timestamp}

  // ── Tracking ──
  // ID of the last message from vendor — used for "waiting for vendor" logic
  lastVendorMessageAt DateTime?
  lastAdminMessageAt  DateTime?
  // Vendor-side unread count (admin messages vendor hasn't seen)
  vendorUnreadCount   Int      @default(0)
  // Admin-side unread count (vendor messages admin hasn't seen)
  adminUnreadCount    Int      @default(0)

  // ── Merge support ──
  mergedIntoId    String?  // if this ticket was merged into another

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  resolvedAt      DateTime?
  closedAt        DateTime?

  // ── Relations ──
  messages        SupportMessage[]

  @@index([vendorId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt])
  @@index([vendorId, status])
  @@map("support_tickets")
}

model SupportMessage {
  id              String   @id @default(cuid())
  ticketId        String
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // "vendor" | "admin" | "system" (system = automated status changes)
  senderType      String
  senderId        String?  // vendor id or admin user id
  senderName      String   // display name snapshot
  senderAvatar    String?  // avatar URL snapshot

  // Message body (plain text — supports emoji)
  body            String

  // Attachments: JSON array of {type: "image"|"pdf"|"document", url, name, size}
  attachments     String?

  createdAt       DateTime @default(now())

  @@index([ticketId])
  @@index([senderType])
  @@index([createdAt])
  @@map("support_messages")
}

// ── Business Types (DB-driven, admin-managed) ──────────────────────────────
// Each category can have its own set of business types.
// Admins can add/remove business types without code changes.
model BusinessType {
  id          String   @id @default(cuid())
  categoryId  String   // maps to Vendor.category (e.g. "bakers-bakery")
  value       String   // e.g. "home_baker"
  label       String   // e.g. "Home Baker"
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([categoryId, value])
  @@index([categoryId, active])
  @@map("business_types")
}
