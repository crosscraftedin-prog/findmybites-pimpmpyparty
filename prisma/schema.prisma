// FindMyBites x PimpMyParty - Global Marketplace Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Authenticated user (vendor). NOTE: Supabase Auth manages users in its own
// auth.users table — this model is optional and kept for future use (e.g.
// storing extra profile fields). The Vendor.userEmail is a plain string, not
// a FK to this table, to avoid constraint failures.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
}

// A vendor / business listed on the marketplace.
// ecosystem: "FINDMYBITES" (food) or "PIMPMYPARTY" (events & party services)
model Vendor {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  ecosystem        String
  category         String
  tagline          String
  description      String
  city             String
  country          String
  countryCode      String
  continent        String
  currency         String
  priceRange       String
  basePrice        Int
  rating           Float     @default(0)
  reviewCount      Int       @default(0)
  heroImage        String
  avatarImage      String
  gallery          String
  tags             String
  featured         Boolean   @default(false)
  verified         Boolean   @default(true)
  // approval workflow: new vendor listings are pending (approved=false) until
  // an admin approves them. Only approved vendors show on the public site.
  approved         Boolean   @default(false)
  responseTime     String
  yearsActive      Int       @default(1)
  completedBookings Int      @default(0)
  // contact + location details (optional, added for richer listings)
  subcategory      String?
  state            String?
  address          String?
  zipCode          String?
  instagram        String?
  website          String?
  whatsapp         String?
  // geo coordinates for "Near Me" search (degrees). Nullable so legacy
  // vendors without a geocoded address are simply excluded from geo queries.
  latitude         Float?
  longitude        Float?
  // how far (km) this vendor will travel to serve a customer. Null = no limit
  // (e.g. a venue the customer travels to, or a vendor serving worldwide).
  serviceRadiusKm  Int?
  // owner: the authenticated vendor user who created this listing.
  // Stored as a plain string (not a FK) because auth users live in Supabase's
  // auth.users table, not our User table — a FK constraint would fail.
  userEmail        String?
  createdAt        DateTime  @default(now())
  reviews          Review[]
  bookings         Booking[]

  @@index([ecosystem])
  @@index([category])
  @@index([continent])
  @@index([featured])
  @@index([priceRange])
  @@index([rating])
  @@index([basePrice])
  @@index([countryCode])
  @@index([createdAt])
  // composite indexes for the most common filter+sort combos at scale
  @@index([ecosystem, category])
  @@index([ecosystem, continent])
  @@index([ecosystem, featured])
  @@index([ecosystem, priceRange])
  @@index([ecosystem, rating])
}

model Review {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  author    String
  avatar    String
  rating    Int
  comment   String
  eventDate String?
  createdAt DateTime @default(now())

  @@index([vendorId])
}

model Booking {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name      String
  email     String
  eventType String
  eventDate String
  eventCity String
  guests    Int
  budget    String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([vendorId])
}
